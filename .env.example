# Database
DATABASE_URL="postgresql://dreamweaver:your_password@localhost:5432/dreamweaver?schema=public"

# Auth.js / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# AI Provider — 任选其一，修改下面三行即可（OpenAI 兼容接口）

# 方案 A：智谱 AI（推荐，open.bigmodel.cn 申请 API Key）
AI_API_KEY="your-zhipu-api-key"
AI_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
AI_MODEL="glm-4-flash"

# 方案 B：阿里云百炼 / 通义千问
# AI_API_KEY="your-dashscope-api-key"
# AI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# AI_MODEL="qwen-plus"

# Rate limiting (interpretations per user per hour)
AI_RATE_LIMIT_PER_HOUR=10
